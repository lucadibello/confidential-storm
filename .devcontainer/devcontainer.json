{
  "name": "Teaclave+Storm devcontainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "REMOTE_USER": "dev",
      "REMOTE_UID": "${localEnv:REMOTE_UID}",
      "REMOTE_GID": "${localEnv:REMOTE_GID}",
      "NODE_VERSION": "16.20.2",
      "STORM_VERSION": "2.8.3",
      "GIT_EMAIL": "lucadibello@proton.me",
      "GIT_NAME": "Luca Di Bello"
    }
  },
  "remoteUser": "dev",
  "runArgs": [
    "--name=confidential-storm-devcontainer",
    "--privileged",
    "--device=/dev/sgx_enclave:/dev/sgx/enclave",
    "--device=/dev/sgx_provision:/dev/sgx/provision",
    "--device=/dev/sgx_vepc:/dev/sgx/vepc",
    "--env-file",
    ".env",
    "--network",
    "storm-net",
    "--publish",
    "127.0.0.1:2222:2222"
  ],
  "overrideCommand": false,
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "forwardPorts": [2222],
  "mounts": [
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind",
    "source=${localWorkspaceFolder}/conf/storm.yaml,target=/home/dev/.storm/storm.yaml,type=bind,readonly",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "containerEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "postCreateCommand": "sudo passwd dev && mkdir -p /home/dev/.ssh && chmod 700 /home/dev/.ssh && ([ -f /home/dev/.ssh/id_ed25519 ] || ssh-keygen -t ed25519 -f /home/dev/.ssh/id_ed25519 -N '' -C 'dev@confidential-storm-devcontainer')",
  "postStartCommand": "sudo chmod 666 /var/run/docker.sock || true"
}
