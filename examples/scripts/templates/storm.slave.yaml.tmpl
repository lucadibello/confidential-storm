# Rendered by examples/scripts/grid_search/config_render.py
# Slave role: Supervisor only (plus optional Logviewer for UI log links).

storm.zookeeper.servers:
  - "$master_host"
storm.zookeeper.port: $zk_port

nimbus.seeds: ["$master_host"]
nimbus.thrift.port: $nimbus_thrift_port

storm.local.dir: "/data"
storm.log.dir: "/logs/storm"

# This slave's externally-reachable address.  Storm uses this when
# Nimbus assigns workers and when other supervisors open netty
# connections to the workers running here.
storm.local.hostname: "$slave_host"

supervisor.slots.ports:
$slot_ports_yaml

logviewer.port: $logviewer_port
